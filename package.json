{
  "name": "ma-yu-product-lab",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "serve out",
    "preview:static": "serve out",
    "dev:cloudflare": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build:cloudflare": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start:cloudflare": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern out",
    "check:export": "node scripts/check-static-export.mjs",
    "prepare:pages": "node scripts/prepare-github-pages.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "serve": "^14.2.4",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
